platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # ហៅប្រើប្រាស់ Podfile របស់ Flutter
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # កម្ទេច Flag -G
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |flag|
          if config.build_settings[flag]
            config.build_settings[flag] = config.build_settings[flag].to_s.gsub('-G', '')
          end
        end
      end
    end
  end
end